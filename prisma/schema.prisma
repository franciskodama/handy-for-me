generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id       String   @id @default(uuid()) @db.VarChar(255)
  uid      String  @unique 
  name     String? 
  avatar   String? 
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model SpinList {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  items     SpinItem[]
}

model SpinItem {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  selected  Boolean   @default(true)
  list      SpinList @relation(fields: [listId], references: [id])
  listId    String
}

model VisualBoardItem {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  url       String
  done      Boolean
}


model BucketListItem {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  category  String
  done      Boolean
}

model ShortcutCategory {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  color     shortcut_color_enum    @default(GRAY)
  shortcuts Shortcut[]
}

enum shortcut_color_enum {
  BLUE
  GREEN
  RED
  YELLOW
  PURPLE
  ORANGE
  PINK
  TEAL
  GRAY
  BROWN
  BLACK
}

model Shortcut {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  name      String   
  url       String
  description String @default("No description yet")
  categoryId  String   
  category    ShortcutCategory @relation(fields: [categoryId], references: [id])
}

model WeeklyWin {
  id        String   @id @default(uuid()) @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  uid       String   
  task      String   
  type      String
  done      Boolean
}