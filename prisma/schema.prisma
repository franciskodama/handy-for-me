generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model users {
  id         String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  username   String?
  email      String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)
}
